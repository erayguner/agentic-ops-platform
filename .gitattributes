# Repository-wide Git behaviour.
#
# Goals:
#   1. Force LF line endings on all text so cross-platform commits don't churn.
#   2. Mark known binaries so Git doesn't try to diff or merge them.
#   3. Route large binary asset types through Git LFS.
#   4. Tell GitHub's Linguist what to count for language stats.
#
# To enable LFS in a clone of this repo:
#   git lfs install
#   git lfs pull

# ─── Default: auto-detect, force LF on commit ────────────────────────────────
* text=auto eol=lf

# ─── Text formats (explicit) ────────────────────────────────────────────────
*.md          text eol=lf diff=markdown
*.py          text eol=lf diff=python
*.pyi         text eol=lf diff=python
*.tf          text eol=lf
*.tfvars      text eol=lf
*.hcl         text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.json        text eol=lf
*.jsonc       text eol=lf
*.toml        text eol=lf
*.txt         text eol=lf
*.sh          text eol=lf
*.bash        text eol=lf
*.zsh         text eol=lf
*.fish        text eol=lf
*.cfg         text eol=lf
*.ini         text eol=lf
*.env.example text eol=lf
*.proto       text eol=lf
*.graphql     text eol=lf
*.sql         text eol=lf
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
Makefile      text eol=lf
*.mk          text eol=lf
*.csv         text eol=lf
*.tsv         text eol=lf

# Dotfiles & meta
.gitignore              text eol=lf
.gitattributes          text eol=lf
.editorconfig           text eol=lf
.pre-commit-config.yaml text eol=lf
.python-version         text eol=lf
.tool-versions          text eol=lf
.dockerignore           text eol=lf
.markdownlintrc         text eol=lf

# ─── Windows-native scripts: keep CRLF ───────────────────────────────────────
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ─── Binary formats (no diff, no merge) ──────────────────────────────────────
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.eot   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.so    binary
*.dylib binary
*.dll   binary
*.exe   binary
*.pyc   binary
*.pyd   binary
*.class binary
*.jar   binary
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.vsdx  binary
*.drawio binary
*.svg   text eol=lf

# ─── Git LFS — large binary assets ───────────────────────────────────────────
# Container images, ML model weights, large archives, datasets, captures.
*.bin         filter=lfs diff=lfs merge=lfs -text
*.onnx        filter=lfs diff=lfs merge=lfs -text
*.pb          filter=lfs diff=lfs merge=lfs -text
*.h5          filter=lfs diff=lfs merge=lfs -text
*.ckpt        filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.pt          filter=lfs diff=lfs merge=lfs -text
*.pth         filter=lfs diff=lfs merge=lfs -text
*.tflite      filter=lfs diff=lfs merge=lfs -text
*.gguf        filter=lfs diff=lfs merge=lfs -text
*.parquet     filter=lfs diff=lfs merge=lfs -text
*.arrow       filter=lfs diff=lfs merge=lfs -text
*.feather     filter=lfs diff=lfs merge=lfs -text
*.avro        filter=lfs diff=lfs merge=lfs -text
*.orc         filter=lfs diff=lfs merge=lfs -text
*.npz         filter=lfs diff=lfs merge=lfs -text
*.npy         filter=lfs diff=lfs merge=lfs -text
*.tar.gz      filter=lfs diff=lfs merge=lfs -text
*.tar.bz2     filter=lfs diff=lfs merge=lfs -text
*.tar.zst     filter=lfs diff=lfs merge=lfs -text
*.tgz         filter=lfs diff=lfs merge=lfs -text
*.tar         filter=lfs diff=lfs merge=lfs -text
*.zip         filter=lfs diff=lfs merge=lfs -text
*.7z          filter=lfs diff=lfs merge=lfs -text
*.pcap        filter=lfs diff=lfs merge=lfs -text
*.pcapng      filter=lfs diff=lfs merge=lfs -text
*.iso         filter=lfs diff=lfs merge=lfs -text
*.dmg         filter=lfs diff=lfs merge=lfs -text
*.qcow2       filter=lfs diff=lfs merge=lfs -text
*.vmdk        filter=lfs diff=lfs merge=lfs -text
*.mp4         filter=lfs diff=lfs merge=lfs -text
*.mov         filter=lfs diff=lfs merge=lfs -text
*.webm        filter=lfs diff=lfs merge=lfs -text

# ─── GitHub Linguist hints ───────────────────────────────────────────────────
# Don't count generated lockfiles toward language stats.
.terraform.lock.hcl  linguist-generated=true
uv.lock              linguist-generated=true
poetry.lock          linguist-generated=true
package-lock.json    linguist-generated=true
yarn.lock            linguist-generated=true
pnpm-lock.yaml       linguist-generated=true
Cargo.lock           linguist-generated=true

# Collapse diffs for vendored code
vendor/**       linguist-vendored=true
third_party/**  linguist-vendored=true

# Mark docs explicitly
docs/**         linguist-documentation=true
